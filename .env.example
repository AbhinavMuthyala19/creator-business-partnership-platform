# Copy this file to .env and fill in real values before running docker-compose.
# Never commit the real .env file.

# --- Database ---
DB_NAME=escobar_club
DB_USERNAME=escobar
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# --- Auth / JWT ---
# Must be a long, random string (32+ bytes) in any real environment.
JWT_SECRET=change-this-to-a-long-random-string-before-deploying
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Apify (Instagram post metrics scraper) ---
# Unofficial scraper, not Meta's Graph API - same ToS caveat applies. Get a token from
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=change-me
APIFY_ACTOR_ID=apify~instagram-scraper
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_TIMEOUT_MS=120000
METRICS_SYNC_MIN_INTERVAL_MINUTES=15

# --- Frontend (local dev only, used by Vite) ---
VITE_API_PROXY_TARGET=http://localhost:8080
